<%layout("/layouts/boilerplate") %>
<body>
    <br>
 <div class="row">
   <div class="col-8 offset-2">
    
     <h3>Add new Listing :</h3>
    
   <form method="post" action="/listings" novalidate class="needs-validation">
    <div class="mb-3">
        <label for="title" class="form-label" >Title</label>
        <input type="text" name="listing[title]" placeholder="Add a catchy title" id="title" class="form-control" required>
        <div class="valid-feedback">Title Looks good!</div>
        <div class="invalid-feedback">Please enter valid price</div>
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea type="text" name="listing[description]" placeholder="description" id="description" class="form-control" required></textarea>
    </div>

   

    <div class="mb-3">
        <label for="image" class="form-label">Image Link</label>
        <input type="text" name="listing[image][url]" placeholder="type url/link" id="image" class="form-control" >
    </div>

    <div class="row">
     <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input  name="listing[price]" placeholder="price" id="price" class="form-control" required>
         <div class="invalid-feedback">Please enter valid Price</div>
    </div>


    <div class="mb-3 col-md-8">
        <label for="country" class="form-label">Country</label>
        <input type="text" name="listing[country]" placeholder="country" id="country" class="form-control" required>
        <div class="invalid-feedback">Please enter valid Country Name</div>
    </div>

    </div>

    <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input type="text" name="listing[location]" placeholder="location" id="location" class="form-control" required>
        <div class="invalid-feedback">Please enter valid Location</div>
    </div>
    

        <button class="btn btn-dark add-btn mt-3">Add</button>
        <br><br>

    </form> 
 </div>
</div>
    
</body>
