<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h3>Add new Listing :</h3>
   <form method="post" action="/listings">
        
        <input type="text" name="listing[title]" placeholder="title" id="title"><br><br>
        <textarea type="text" name="listing[description]" placeholder="description" id="description"></textarea><br><br>
        <input type="number" name="listing[price]" placeholder="price" id="price"><br><br>
        <input type="text" name="listing[image]" placeholder="type url/link" id="image"><br><br>
        <input type="text" name="listing[country]" placeholder="country" id="country"><br><br>
        <input type="text" name="listing[location]" placeholder="location" id="location"><br><br>
        <button>Add</button>

    </form> 
    
</body>
</html>